# Aarogya Backend Environment Variables Example
PORT=4000
NODE_ENV=development

# Supabase Configurations
SUPABASE_URL=https://your-supabase-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Krutrim Cloud AI API Configurations
KRUTRIM_BASE_URL=https://cloud.olakrutrim.com/v1
KRUTRIM_API_KEY=your-krutrim-api-key

# Sarvam AI API Configurations
SARVAM_API_KEY=your-sarvam-api-key

# Session secret used for signing temporary assistant confirmation tokens
JWT_SECRET=your-secure-random-signing-secret-key-phrase
